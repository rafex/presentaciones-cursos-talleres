# Plantilla -- copia esto, llena tu API key real, y cifra el resultado.
# NUNCA commitees este archivo con un valor real sin cifrar.
#
#   cp secrets/groq.example.env secrets/groq.enc.env
#   $EDITOR secrets/groq.enc.env          # pega tu LLM_TOKEN real
#   sops --encrypt --in-place secrets/groq.enc.env
#
LLM_TYPE=openai
LLM_URL=https://api.groq.com/openai
LLM_TOKEN=gsk_tu_api_key_real_aqui
LLM_MODEL=llama-3.3-70b-versatile
